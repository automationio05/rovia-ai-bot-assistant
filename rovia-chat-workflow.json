    {
      "parameters": {
        "jsCode": "let raw = $json.output?.[0]?.content?.[0]?.text || \"\";\n\nraw = raw.replace(/```json|```/g, \"\").trim();\n\nlet parsed;\n\ntry {\n  parsed = JSON.parse(raw);\n} catch (e) {\n  parsed = {\n    reply: raw || \"Sorry, I couldn't understand.\",\n    intent: \"help\",\n    confidence: \"low\"\n  };\n}\n\nreturn [{ json: parsed }];"
      },
